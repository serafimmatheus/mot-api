// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now()) @db.Timestamptz()
  updatedAt     DateTime @updatedAt @db.Timestamptz()

  accounts            Account[]
  sessions            Session[]
  patientCaregivers   PatientCaregiver[]
  careEventsPerformed CareEvent[]

  @@map("user")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// --- Cuidar Juntos: pacientes, insumos, medicamentos e eventos de cuidado ---

enum CareEventType {
  SUPPLY_CONSUMED
  MEDICATION_APPLIED
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  caregivers       PatientCaregiver[]
  caregiverInvites PatientCaregiverInvite[]
  supplies         Supply[]
  medications      Medication[]
  careEvents       CareEvent[]

  @@map("patient")
}

/// N:N — um paciente pode ter vários cuidadores; um usuário pode cuidar de vários pacientes.
model PatientCaregiver {
  patientId String
  userId    String
  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([patientId, userId])
  @@index([userId])
  @@map("patient_caregiver")
}

model PatientCaregiverInvite {
  id        String   @id @default(cuid())
  patientId String
  email     String
  token     String   @unique
  expiresAt DateTime @db.Timestamptz()
  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, email])
  @@index([email])
  @@map("patient_caregiver_invite")
}

model Supply {
  id              String @id @default(cuid())
  patientId       String
  name            String
  currentQuantity Int    @default(0)
  minQuantity     Int    @default(0)
  unit            String

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  careEvents CareEvent[]

  @@index([patientId])
  @@map("supply")
}

model Medication {
  id        String @id @default(cuid())
  patientId String
  name      String
  dosage    String
  /// Horários / frequência em JSON (ex.: `{ "times": ["08:00","20:00"] }`).
  schedule  Json?

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  careEvents CareEvent[]

  @@index([patientId])
  @@map("medication")
}

model CareEvent {
  id                String        @id @default(cuid())
  patientId         String
  type              CareEventType
  /// Quantidade usada (insumo) ou aplicada, quando fizer sentido.
  quantity          Int?
  notes             String?
  supplyId          String?
  medicationId      String?
  performedByUserId String

  occurredAt DateTime @default(now()) @db.Timestamptz()
  createdAt  DateTime @default(now()) @db.Timestamptz()

  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  supply      Supply?     @relation(fields: [supplyId], references: [id], onDelete: SetNull)
  medication  Medication? @relation(fields: [medicationId], references: [id], onDelete: SetNull)
  performedBy User        @relation(fields: [performedByUserId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([supplyId])
  @@index([medicationId])
  @@index([performedByUserId])
  @@map("care_event")
}
